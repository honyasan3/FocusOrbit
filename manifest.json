{
  "manifest_version": 3,
  "name": "FocusOrbit",
  "version": "1.0.0",
  "description": "Reduce cognitive load by managing tabs with contexts and smart archiving.",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["palette.js"],
      "all_frames": false
    }
  ]
}